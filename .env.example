# Copia este archivo como .env para desarrollo local
# NUNCA subas .env a git

# --- Base de datos PostgreSQL ---
# En producción (Render) DATABASE_URL lo pone Render automáticamente
# En local apunta a tu instancia local de PostgreSQL
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/AML

# --- Autenticación JWT (API) ---
# Genera un valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_un_valor_seguro

# --- URL del API (Frontend Streamlit) ---
# En local: http://localhost:8000
# En Render: https://sovereign-aml-api.onrender.com
AUTH_API_URL=http://localhost:8000
